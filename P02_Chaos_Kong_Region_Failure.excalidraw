    {
      "id": "lesson-text", "type": "text",
      "x": 30, "y": 747, "width": 1060, "height": 38,
      "text": "A secondary region that has never served real production traffic is not a backup — it is an untested hope.\nEvery bug Chaos Kong found existed for months. None appeared in staging. All appeared the moment real traffic hit a region it had never served before.",
      "fontSize": 12, "fontFamily": 1,
      "strokeColor": "#a6adc8", "backgroundColor": "transparent",
