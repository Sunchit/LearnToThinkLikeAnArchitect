    {
      "id": "bug3-exp-text", "type": "text",
      "x": 740, "y": 573, "width": 340, "height": 126,
      "text": "BUG 3 — CDN Routing Loop\n──────────────────────────\nRoot cause:\nCDN edge nodes had origin\nfallback hardcoded to us-east-1\nIP. When east-1 went down, every\nvideo request looped back to a\ndead endpoint — zero playback.\n\nFix: CDN origin config uses a\nGlobal Accelerator anycast address\nthat routes to the nearest healthy\nregion automatically.",
      "fontSize": 11, "fontFamily": 1,
      "strokeColor": "#ffee66", "backgroundColor": "transparent",
      "fillStyle": "solid", "strokeWidth": 1, "roughness": 0, "opacity": 100,
      "textAlign": "left", "verticalAlign": "top",
      "seed": 921, "version": 1, "versionNonce": 921,
      "isDeleted": false, "boundElements": null, "updated": 1,
      "link": null, "locked": false, "containerId": null,
      "originalText": "BUG 3 — CDN Routing Loop\n──────────────────────────\nRoot cause:\nCDN edge nodes had origin\nfallback hardcoded to us-east-1\nIP. When east-1 went down, every\nvideo request looped back to a\ndead endpoint — zero playback.\n\nFix: CDN origin config uses a\nGlobal Accelerator anycast address\nthat routes to the nearest healthy\nregion automatically.",
      "angle": 0, "groupIds": []
    },

